# ============================================================
#  ERP Enterprise — Plantilla de variables de entorno
#  Archivo: sistema_gestion/.env.example
#
#  USO: copiar este archivo como .env y completar los valores.
#       cp .env.example .env
#
#  Este archivo SÍ se sube al repositorio (no tiene secretos reales).
# ============================================================

# ── Django core ─────────────────────────────────────────────
SECRET_KEY=cambiar-por-clave-segura-generada-con-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# ── Base de datos ────────────────────────────────────────────
DB_NAME=erp_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email ─────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_aqui
DEFAULT_FROM_EMAIL=Mi ERP <tu_correo@gmail.com>

# ── Storage ───────────────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadminpassword
AWS_STORAGE_BUCKET_NAME=erp-media-local
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_CUSTOM_DOMAIN=localhost:9000/erp-media-local

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=
